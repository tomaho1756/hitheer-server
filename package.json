{
  "name": "hithere",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev:web": "pnpm --filter @hithere/web dev",
    "dev:signaling": "cargo run --manifest-path apps/signaling/Cargo.toml",
