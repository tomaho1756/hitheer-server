# Copy to .env.local and fill in from Firebase console:
# Project Settings → General → Your apps → </> Web → Config

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=hitheer-app.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=hitheer-app
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=hitheer-app.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Signaling URLs default to same origin via Next.js rewrites. In production
# (Firebase App Hosting + Cloud Run signaling), point these at the Cloud Run URL:
# NEXT_PUBLIC_SIGNALING_URL=wss://api.hithere.example/ws
# NEXT_PUBLIC_SIGNALING_HTTP=https://api.hithere.example
