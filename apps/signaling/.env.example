# Copy to .env and fill in. The .env file is gitignored.

# Required for STT/translation subtitles. Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional overrides
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_TRANSCRIBE_MODEL=whisper-1

# Optional — leave empty if you're not running TURN
TURN_STATIC_AUTH_SECRET=
TURN_URIS=
TURN_TTL_SECS=3600

# Redis (defaults to localhost:6379 if unset)
REDIS_URL=redis://127.0.0.1:6379
