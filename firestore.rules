rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each user can only read/write their own profile doc + subtree.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Stripe event log — admin-only (webhook writes via firebase-admin SDK).
    // Clients should never touch this.
    match /stripe_events/{eventId} {
      allow read, write: if false;
    }

    // Friend requests: sender A can create the request doc at
    // users/{B}/friend_requests/{A}; recipient B can read/delete from their
    // own subtree. The acceptance flow (creating the mutual friend docs in
    // both subtrees) goes through the /api/friends/accept route using admin
    // SDK, so we don't need cross-user write rules here.
    match /users/{recipientUid}/friend_requests/{senderUid} {
      allow create: if request.auth != null
        && request.auth.uid == senderUid
        && request.resource.data.keys().hasOnly(
             ['senderUid', 'senderName', 'senderEmail', 'status', 'createdAt']
           );
      // The recipient already has read/delete via the generic users/{uid}/{**} rule above.
    }

    // Invitations: A initiates a friend call by writing
    // users/{B}/invitations/{roomId}. The friend client listens for these.
    match /users/{recipientUid}/invitations/{roomId} {
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.fromUid
        && request.resource.data.keys().hasOnly(
             ['fromUid', 'fromName', 'roomId', 'mineLang', 'peerLang', 'createdAt']
           );
    }

    // Public uid <-> email lookup directory. Each user writes a single doc at
    // user_lookup/{uid} with their own email; anyone authenticated can read
    // (so friend search works) but only owner can write.
    match /user_lookup/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    // (future) shared resources go here with explicit rules.
  }
}
